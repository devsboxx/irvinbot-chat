DATABASE_URL=postgresql://postgres:postgres@localhost:5432/irvinbot_chat
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# LLM: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Model override (optional, uses sensible default per provider)
LLM_MODEL=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8004
CHROMA_COLLECTION=thesis_docs
