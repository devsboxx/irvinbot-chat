DATABASE_URL=postgresql://postgres:postgres@localhost:5432/irvinbot_chat
SECRET_KEY=5e40cff-f86d-4efc-b389-342344ffd037
ALGORITHM=HS256

# ── LLM ───────────────────────────────────────────────────────────────────────
# Opciones: ollama | groq | openai | anthropic
# Default: ollama (sin API key, gratis)
LLM_PROVIDER=ollama
# Modelo a usar. Vacío = default del proveedor:
#   ollama   → llama3.2
#   groq     → llama-3.3-70b-versatile
#   openai   → gpt-4o
#   anthropic→ claude-sonnet-4-6
LLM_MODEL=

# ── Embeddings ────────────────────────────────────────────────────────────────
# Opciones: ollama | openai
# Default: ollama (sin API key, gratis)
EMBEDDING_PROVIDER=ollama
# Modelo de embeddings. Vacío = default del proveedor:
#   ollama → nomic-embed-text
#   openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (solo agrega la del proveedor que uses) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Ollama (si LLM_PROVIDER=ollama o EMBEDDING_PROVIDER=ollama) ──────────────
# URL donde corre Ollama localmente
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8004
CHROMA_COLLECTION=thesis_docs
