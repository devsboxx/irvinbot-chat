# Base de datos — para desarrollo local usa localhost:5432
# En Docker el docker-compose sobreescribe DATABASE_URL automáticamente
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/irvinbot_chat

# JWT — CRÍTICO: debe ser idéntico en auth, chat, docs y gateway
# Genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-secreto-igual-en-todos-los-servicios
ALGORITHM=HS256

# ── LLM ───────────────────────────────────────────────────────────────────────
# Opciones: ollama | groq | openai | anthropic
# - ollama:    gratis, corre en tu máquina. Requiere `ollama serve` + modelo descargado
# - groq:      gratis (tier gratuito), requiere GROQ_API_KEY de console.groq.com
# - openai:    pago, requiere OPENAI_API_KEY
# - anthropic: pago, requiere ANTHROPIC_API_KEY
LLM_PROVIDER=ollama

# Modelo a usar. Vacío = default del proveedor:
#   ollama    → llama3.2
#   groq      → llama-3.3-70b-versatile
#   openai    → gpt-4o
#   anthropic → claude-sonnet-4-6
LLM_MODEL=

# ── Embeddings ────────────────────────────────────────────────────────────────
# Opciones: ollama | openai
# - ollama: gratis, corre en tu máquina. Modelo recomendado: nomic-embed-text
# - openai: pago, requiere OPENAI_API_KEY
EMBEDDING_PROVIDER=ollama

# Modelo de embeddings. Vacío = default del proveedor:
#   ollama → nomic-embed-text
#   openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (rellena solo la del proveedor activo) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Ollama (si LLM_PROVIDER=ollama o EMBEDDING_PROVIDER=ollama) ───────────────
# Desarrollo local:
OLLAMA_BASE_URL=http://localhost:11434
# Dentro de Docker en Mac/Windows (Ollama corre en el host):
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Desarrollo local: ChromaDB corre en localhost:8004
CHROMA_HOST=localhost
CHROMA_PORT=8004
CHROMA_COLLECTION=methodology_guide
# Dentro de Docker el docker-compose sobreescribe CHROMA_HOST=chromadb y CHROMA_PORT=8000
# Ejecutar el seeding: python scripts/seed_methodology.py
